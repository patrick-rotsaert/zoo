{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "core",
            "hidden": true,
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "installDir": "${sourceDir}/out/install/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "ccache",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
                "CMAKE_C_COMPILER_LAUNCHER": "ccache"
            },
            "environment": {
                "CCACHE_BASEDIR": "${sourceDir}",
                "CCACHE_NOHASHDIR": "true",
                "CCACHE_SLOPPINESS": "pch_defines,time_macros"
            }
        },
        {
            "name": "windows",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "linux",
            "hidden": true,
            "generator": "Ninja Multi-Config",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "vcpkg",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
            }
        },
        {
            "name": "shared",
            "hidden": true,
            "cacheVariables": {
                "BUILD_SHARED_LIBS": "True"
            }
        },
        {
            "name": "static",
            "hidden": true,
            "cacheVariables": {
                "BUILD_SHARED_LIBS": "False"
            }
        },
        {
            "name": "vcpkg-x64-linux-shared",
            "hidden": true,
            "inherits": [
                "vcpkg",
                "shared",
                "linux"
            ],
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-linux-dynamic"
            }
        },
        {
            "name": "vc142-x64",
            "hidden": true,
            "generator": "Visual Studio 16 2019",
            "architecture": {
                "value": "x64",
                "strategy": "set"
            },
            "inherits": [
                "windows"
            ]
        },
        {
            "name": "vc142-x86",
            "hidden": true,
            "generator": "Visual Studio 16 2019",
            "architecture": {
                "value": "Win32",
                "strategy": "set"
            },
            "inherits": [
                "windows"
            ]
        },
        {
            "name": "gcc",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "g++"
            }
        },
        {
            "name": "vc142-x64-shared",
            "displayName": "VS2019 x64 Shared",
            "inherits": [
                "core",
                "vc142-x64",
                "shared",
                "vcpkg"
            ]
        },
        {
            "name": "vc142-x64-static",
            "displayName": "VS2019 x64 Static",
            "inherits": [
                "core",
                "vc142-x64",
                "static",
                "vcpkg"
            ]
        },
        {
            "name": "vc142-x86-shared",
            "displayName": "VS2019 x86 Shared",
            "inherits": [
                "core",
                "vc142-x86",
                "shared",
                "vcpkg"
            ]
        },
        {
            "name": "vc142-x86-static",
            "displayName": "VS2019 x86 Static",
            "inherits": [
                "core",
                "vc142-x86",
                "static",
                "vcpkg"
            ]
        },
        {
            "name": "linux-x64-gcc-shared",
            "displayName": "Linux x64 GCC Shared",
            "inherits": [
                "linux",
                "core",
                "ccache",
                "gcc",
                "shared"
            ]
        },
        {
            "name": "linux-x64-gcc-static",
            "displayName": "Linux x64 GCC Static",
            "inherits": [
                "linux",
                "core",
                "ccache",
                "gcc",
                "static"
            ]
        },
        {
            "name": "linux-x64-gcc-shared-vcpkg",
            "displayName": "Linux x64 GCC Shared Vcpkg",
            "inherits": [
                "linux",
                "core",
                "ccache",
                "gcc",
                "vcpkg-x64-linux-shared"
            ]
        },
        {
            "name": "linux-x64-gcc-static-vcpkg",
            "displayName": "Linux x64 GCC Static Vcpkg",
            "inherits": [
                "linux",
                "core",
                "ccache",
                "gcc",
                "static",
                "vcpkg"
            ]
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "hidden": true,
            "configuration": "Debug"
        },
        {
            "name": "release",
            "hidden": true,
            "configuration": "Release"
        },
        {
            "name": "vc142-x64-shared-debug",
            "displayName": "VS2019 x64 Shared Debug",
            "configurePreset": "vc142-x64-shared",
            "inherits": "debug"
        },
        {
            "name": "vc142-x64-shared-release",
            "displayName": "VS2019 x64 Shared Release",
            "configurePreset": "vc142-x64-shared",
            "inherits": "release"
        },
        {
            "name": "vc142-x64-static-debug",
            "displayName": "VS2019 x64 Static Debug",
            "configurePreset": "vc142-x64-static",
            "inherits": "debug"
        },
        {
            "name": "vc142-x64-static-release",
            "displayName": "VS2019 x64 Static Release",
            "configurePreset": "vc142-x64-static",
            "inherits": "release"
        },
        {
            "name": "vc142-x86-shared-debug",
            "displayName": "VS2019 x86 Shared Debug",
            "configurePreset": "vc142-x86-shared",
            "inherits": "debug"
        },
        {
            "name": "vc142-x86-shared-release",
            "displayName": "VS2019 x86 Shared Release",
            "configurePreset": "vc142-x86-shared",
            "inherits": "release"
        },
        {
            "name": "vc142-x86-static-debug",
            "displayName": "VS2019 x86 Static Debug",
            "configurePreset": "vc142-x86-static",
            "inherits": "debug"
        },
        {
            "name": "vc142-x86-static-release",
            "displayName": "VS2019 x86 Static Release",
            "configurePreset": "vc142-x86-static",
            "inherits": "release"
        },
        {
            "name": "linux-x64-gcc-shared-debug",
            "displayName": "Linux x64 GCC Shared Debug",
            "configurePreset": "linux-x64-gcc-shared",
            "inherits": "debug"
        },
        {
            "name": "linux-x64-gcc-shared-release",
            "displayName": "Linux x64 GCC Shared Release",
            "configurePreset": "linux-x64-gcc-shared",
            "inherits": "release"
        },
        {
            "name": "linux-x64-gcc-static-debug",
            "displayName": "Linux x64 GCC Static Debug",
            "configurePreset": "linux-x64-gcc-static",
            "inherits": "debug"
        },
        {
            "name": "linux-x64-gcc-static-release",
            "displayName": "Linux x64 GCC Static Release",
            "configurePreset": "linux-x64-gcc-static",
            "inherits": "release"
        },
        {
            "name": "linux-x64-gcc-shared-debug-vcpkg",
            "displayName": "Linux x64 GCC Shared Debug Vcpkg",
            "configurePreset": "linux-x64-gcc-shared-vcpkg",
            "inherits": "debug"
        },
        {
            "name": "linux-x64-gcc-shared-release-vcpkg",
            "displayName": "Linux x64 GCC Shared Release Vcpkg",
            "configurePreset": "linux-x64-gcc-shared-vcpkg",
            "inherits": "release"
        },
        {
            "name": "linux-x64-gcc-static-debug-vcpkg",
            "displayName": "Linux x64 GCC Static Debug Vcpkg",
            "configurePreset": "linux-x64-gcc-static-vcpkg",
            "inherits": "debug"
        },
        {
            "name": "linux-x64-gcc-static-release-vcpkg",
            "displayName": "Linux x64 GCC Static Release Vcpkg",
            "configurePreset": "linux-x64-gcc-static-vcpkg",
            "inherits": "release"
        }
    ]
}
